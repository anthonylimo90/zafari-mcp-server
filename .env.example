# Zafari MCP Server Environment Configuration

# ============================================================================
# REQUIRED CONFIGURATION
# ============================================================================

# Required: Your Zafari CRS API key
# Get this from your Zafari account dashboard
ZAFARI_API_KEY=your-api-key-here

# Required: JWT Secret for signing access tokens
# CRITICAL: Generate a strong secret with at least 32 characters
# Generate with: openssl rand -base64 64
# NEVER commit this to version control!
JWT_SECRET=REQUIRED_CHANGE_THIS_IMMEDIATELY

# Required: User Passwords (minimum 12 characters)
# SECURITY REQUIREMENTS:
# - Minimum 12 characters (16+ recommended for production)
# - Include uppercase, lowercase, numbers, and special characters
# - Never use default or weak passwords in production
# Example strong password: MyS3cure!P@ssw0rd2024
ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DEMO_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ============================================================================
# TRANSPORT CONFIGURATION
# ============================================================================

# Optional: Transport mode
# - stdio: For local CLI usage (legacy)
# - http: For remote access with OAuth (recommended for Claude Desktop)
# Default: stdio
TRANSPORT=http

# Optional: HTTP server configuration (only used when TRANSPORT=http)
# Default: localhost:3000
HOST=localhost
PORT=3000

# ============================================================================
# SECURITY CONFIGURATION
# ============================================================================

# OAuth Issuer and Audience (optional, defaults to server name)
OAUTH_ISSUER=zafari-mcp-server
OAUTH_AUDIENCE=zafari-mcp-api

# Token Storage Backend (optional, default: memory)
# - memory: In-memory storage (development only, tokens lost on restart)
# - redis: Redis storage (production recommended, requires Redis server)
STORAGE_BACKEND=memory

# Redis URL (required if STORAGE_BACKEND=redis)
# Examples:
#   - Local: redis://localhost:6379
#   - Remote: redis://username:password@hostname:port/database
# REDIS_URL=redis://localhost:6379

# CORS Allowed Origins (optional, default: https://claude.ai)
# Comma-separated list of allowed origins
# Examples:
#   - Single: https://claude.ai
#   - Multiple: https://claude.ai,https://your-domain.com
# IMPORTANT: Do not use * in production
ALLOWED_ORIGINS=https://claude.ai

# Allowed OAuth Client IDs (optional, default: claude-desktop,mcp-inspector)
# Comma-separated list of allowed client IDs
ALLOWED_CLIENT_IDS=claude-desktop,mcp-inspector

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================

# Log Level (optional, default: info)
# Options: error, warn, info, http, verbose, debug, silly
LOG_LEVEL=info

# ============================================================================
# ENVIRONMENT
# ============================================================================

# Node Environment (optional, default: development)
# Set to 'production' for production deployments
# This enables additional security checks and warnings
# NODE_ENV=production

# ============================================================================
# PRODUCTION DEPLOYMENT CHECKLIST
# ============================================================================
#
# Before deploying to production, ensure you have:
#
# [ ] Set a strong JWT_SECRET (64+ characters)
# [ ] Set strong passwords (16+ characters with complexity)
# [ ] Set NODE_ENV=production
# [ ] Configure STORAGE_BACKEND=redis with Redis server
# [ ] Set REDIS_URL for Redis connection
# [ ] Configure ALLOWED_ORIGINS for your domains (no wildcard)
# [ ] Configure ALLOWED_CLIENT_IDS for your OAuth clients
# [ ] Review and adjust rate limiting if needed (in src/index.ts)
# [ ] Set up HTTPS/TLS (use reverse proxy like nginx)
# [ ] Enable firewall rules (only 443/80 exposed)
# [ ] Set up monitoring and alerting
# [ ] Review logs regularly for security events
#
# For detailed security guidance, see SECURITY.md
#
# ============================================================================
